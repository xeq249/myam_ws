    <!-- Fixed arm version for 4101 takeoff verification: full mass/geometry kept, arm locked in home pose. -->
    <plugin name='multirotor_base' filename='libgazebo_multirotor_base_plugin.so'>
      <robotNamespace/>
      <linkName>base_link</linkName>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <!-- Motor order: match URDF (x forward, y left). rotor_1=前左, rotor_2=前右, rotor_3=右, rotor_4=后右, rotor_5=后左, rotor_6=左. PX4 0..5 = rotor_1..6 -->
    <plugin name='motor_0' filename='libgazebo_motor_model.so'>
      <robotNamespace/>
      <jointName>rotor_1_link_joint</jointName>
      <linkName>rotor_1_link</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1500</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>0.000806428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/0</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
