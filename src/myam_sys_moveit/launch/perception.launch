<launch>
  <arg name="use_sim_time" default="true"/>
  <param name="/use_sim_time" value="$(arg use_sim_time)"/>

  <arg name="camera_ns" default="/camera"/>
  <arg name="settings_file" default="$(find apriltag_ros)/config/settings.yaml"/>
  <arg name="tags_file" default="$(find apriltag_ros)/config/tags.yaml"/>
  <arg name="publish_tag_detections_image" default="true"/>
  <arg name="publish_tf" default="true"/>
  <arg name="queue_size" default="1"/>

  <node pkg="apriltag_ros" type="apriltag_ros_continuous_node" name="apriltag_ros"
        clear_params="true" output="screen">
    <remap from="image_rect" to="$(arg camera_ns)/color/image_raw"/>
    <remap from="camera_info" to="$(arg camera_ns)/color/camera_info"/>
    <remap from="tag_detections" to="/tag_detections"/>
    <remap from="tag_detections_image" to="/tag_detections_image"/>
    <rosparam command="load" file="$(arg settings_file)"/>
    <rosparam command="load" file="$(arg tags_file)"/>
    <param name="publish_tag_detections_image" type="bool" value="$(arg publish_tag_detections_image)"/>
    <param name="publish_tf" type="bool" value="$(arg publish_tf)"/>
    <param name="queue_size" type="int" value="$(arg queue_size)"/>
  </node>
</launch>
