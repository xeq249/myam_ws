<launch>
  <!-- Default run mode requested by user -->
  <arg name="dry_run" default="false" />
  <arg name="start_camera" default="true" />
  <arg name="roarm_ip" default="192.168.4.1" />
  <arg name="send_pose_only" default="true" />
  <arg name="auto_grasp" default="false" />

  <!-- RealSense topics -->
  <arg name="color_topic" default="/camera/color/image_raw" />
  <arg name="depth_topic" default="/camera/aligned_depth_to_color/image_raw" />
  <arg name="camera_info_topic" default="/camera/color/camera_info" />

  <group if="$(arg start_camera)">
    <include file="$(find realsense2_camera)/launch/rs_camera.launch">
      <arg name="align_depth" value="true" />
      <arg name="enable_color" value="true" />
      <arg name="enable_depth" value="true" />
      <arg name="color_width" value="640" />
      <arg name="color_height" value="480" />
      <arg name="color_fps" value="30" />
      <arg name="depth_width" value="640" />
      <arg name="depth_height" value="480" />
      <arg name="depth_fps" value="30" />
    </include>
  </group>

  <!-- Default light-blue cube detection parameters -->
  <arg name="blue_h_min" default="85" />
  <arg name="blue_h_max" default="115" />
  <arg name="blue_s_min" default="30" />
  <arg name="blue_v_min" default="120" />
  <arg name="min_area" default="300" />
  <arg name="max_area" default="30000" />
  <arg name="depth_roi" default="7" />
  <arg name="depth_min_m" default="0.12" />
  <arg name="depth_max_m" default="2.0" />

  <!-- Camera extrinsic: camera optical frame -> inverted arm base_link.
       User states optical +Z points forward-down and forms 55 deg with horizontal.
       Default pitch=35deg makes +Z_camera map approximately to +X_forward/+Z_down. -->
  <arg name="cam_x" default="0.10" />
  <arg name="cam_y" default="0.0" />
  <arg name="cam_z" default="-0.05" />
  <arg name="cam_roll" default="0.0" />
  <arg name="cam_pitch" default="0.6108652382" />
  <arg name="cam_yaw" default="0.0" />

  <!-- Inverted RoArm user frame: +X forward, +Z downward. Cube is usually front-down, so x,z positive. -->
  <arg name="roarm_x_sign" default="1.0" />
  <arg name="roarm_y_sign" default="1.0" />
  <arg name="roarm_z_sign" default="1.0" />
  <arg name="target_offset_x_mm" default="0" />
  <arg name="target_offset_y_mm" default="0" />
  <arg name="target_offset_z_mm" default="0" />

  <!-- Software range protection disabled by default as requested.
       To re-enable: reject_out_of_range:=true and set limits below. -->
  <arg name="reject_out_of_range" default="false" />
  <arg name="clamp_out_of_range" default="false" />
  <arg name="x_min_mm" default="-10000" />
  <arg name="x_max_mm" default="10000" />
  <arg name="y_min_mm" default="-10000" />
  <arg name="y_max_mm" default="10000" />
  <arg name="z_min_mm" default="-10000" />
  <arg name="z_max_mm" default="10000" />

  <!-- Gripper / motion -->
  <arg name="g_open" default="1.10" />
  <arg name="g_close" default="3.14" />
  <arg name="move_spd" default="0.20" />
  <arg name="use_T104" default="true" />
  <arg name="open_before_move" default="true" />
  <arg name="close_after_move" default="false" />
  <arg name="send_once" default="true" />

  <!-- Stability / filter -->
  <arg name="stable_frames" default="5" />
  <arg name="stable_pixel_tol" default="12" />
  <arg name="filter_alpha" default="0.15" />
  <arg name="max_jump_mm" default="150" />

  <node pkg="roarm_blue_cube_http" type="blue_cube_to_roarm_http.py" name="blue_cube_to_roarm_http" output="screen">
    <param name="dry_run" value="$(arg dry_run)" />
    <param name="roarm_ip" value="$(arg roarm_ip)" />
    <param name="send_pose_only" value="$(arg send_pose_only)" />
    <param name="auto_grasp" value="$(arg auto_grasp)" />

    <param name="color_topic" value="$(arg color_topic)" />
    <param name="depth_topic" value="$(arg depth_topic)" />
    <param name="camera_info_topic" value="$(arg camera_info_topic)" />

    <param name="blue_h_min" value="$(arg blue_h_min)" />
    <param name="blue_h_max" value="$(arg blue_h_max)" />
    <param name="blue_s_min" value="$(arg blue_s_min)" />
    <param name="blue_v_min" value="$(arg blue_v_min)" />
    <param name="min_area" value="$(arg min_area)" />
    <param name="max_area" value="$(arg max_area)" />
    <param name="depth_roi" value="$(arg depth_roi)" />
    <param name="depth_min_m" value="$(arg depth_min_m)" />
    <param name="depth_max_m" value="$(arg depth_max_m)" />

    <param name="cam_x" value="$(arg cam_x)" />
    <param name="cam_y" value="$(arg cam_y)" />
    <param name="cam_z" value="$(arg cam_z)" />
    <param name="cam_roll" value="$(arg cam_roll)" />
    <param name="cam_pitch" value="$(arg cam_pitch)" />
    <param name="cam_yaw" value="$(arg cam_yaw)" />

    <param name="roarm_x_sign" value="$(arg roarm_x_sign)" />
    <param name="roarm_y_sign" value="$(arg roarm_y_sign)" />
    <param name="roarm_z_sign" value="$(arg roarm_z_sign)" />
    <param name="target_offset_x_mm" value="$(arg target_offset_x_mm)" />
    <param name="target_offset_y_mm" value="$(arg target_offset_y_mm)" />
    <param name="target_offset_z_mm" value="$(arg target_offset_z_mm)" />

    <param name="reject_out_of_range" value="$(arg reject_out_of_range)" />
    <param name="clamp_out_of_range" value="$(arg clamp_out_of_range)" />
    <param name="x_min_mm" value="$(arg x_min_mm)" />
    <param name="x_max_mm" value="$(arg x_max_mm)" />
    <param name="y_min_mm" value="$(arg y_min_mm)" />
    <param name="y_max_mm" value="$(arg y_max_mm)" />
    <param name="z_min_mm" value="$(arg z_min_mm)" />
    <param name="z_max_mm" value="$(arg z_max_mm)" />

    <param name="g_open" value="$(arg g_open)" />
    <param name="g_close" value="$(arg g_close)" />
    <param name="move_spd" value="$(arg move_spd)" />
    <param name="use_T104" value="$(arg use_T104)" />
    <param name="open_before_move" value="$(arg open_before_move)" />
    <param name="close_after_move" value="$(arg close_after_move)" />
    <param name="send_once" value="$(arg send_once)" />

    <param name="stable_frames" value="$(arg stable_frames)" />
    <param name="stable_pixel_tol" value="$(arg stable_pixel_tol)" />
    <param name="filter_alpha" value="$(arg filter_alpha)" />
    <param name="max_jump_mm" value="$(arg max_jump_mm)" />
  </node>
</launch>
