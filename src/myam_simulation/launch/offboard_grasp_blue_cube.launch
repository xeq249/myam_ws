<launch>
  <!--
    需在 MAVROS + move_group +（推荐）PX4 SITL + Gazebo 已就绪后启动。
    示例：先 roslaunch myam_simulation sitl_moveit.launch（或你现有的 SITL+MAVROS+MoveIt）
    再本 launch。
  -->
  <arg name="hover_rel_m" default="1.0" doc="相对起飞 local z 的巡航悬停高度（米）"/>
  <arg name="approach_hover_rel_m" default="0.4" doc="前飞到位后下降至该相对高度再识别/抓取（米）"/>
  <arg name="forward_m" default="1.6" doc="机头正前方位移（米）"/>

  <!-- 与 Gazebo myuam realsense 插件一致；若 rqt 里话题名不同，在此覆盖 -->
  <arg name="color_topic" default="/camera_realsense/color/image_raw"/>
  <arg name="depth_topic" default="/camera_realsense/depth/image_raw"/>
  <arg name="camera_info_topic" default="/camera_realsense/color/camera_info"/>

  <node pkg="myam_simulation" type="offboard_grasp_blue_cube.py" name="offboard_grasp_blue_cube" output="screen">
    <param name="hover_rel_m" value="$(arg hover_rel_m)"/>
    <param name="approach_hover_rel_m" value="$(arg approach_hover_rel_m)"/>
    <param name="forward_m" value="$(arg forward_m)"/>
    <param name="try_pose_from_vision" value="true"/>
    <param name="color_topic" value="$(arg color_topic)"/>
    <param name="depth_topic" value="$(arg depth_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
    <param name="auto_arm" value="true"/>
    <param name="auto_offboard" value="true"/>
    <!-- MoveIt 阻塞主线程时须仍有 Offboard 设定点，否则 PX4 Failsafe 切 Position -->
    <param name="offboard_stream_enable" value="true"/>
    <param name="offboard_stream_hz" value="20.0"/>
    <!-- link2_to_link3 上限 2.95，顶格易 CONTROL_FAILED；必须 2.95 时再改大 arm_goal_joint_tolerance 并放慢 arm_home_vel_scaling -->
    <!-- 第三关节略低于 2.95 上限，减轻 effort 仿真里 home 的 CONTROL_FAILED -->
    <rosparam param="arm_home_joints">[0.0, -1.57, 2.93, 0.0, 0.0]</rosparam>
    <param name="arm_goal_joint_tolerance" value="0.12"/>
    <param name="arm_home_vel_scaling" value="0.08"/>
    <param name="arm_home_accel_scaling" value="0.08"/>
    <!-- 抓取阶段会再次 roscpp_initialize，连接 move_group action 默认 5s 易超时 -->
    <param name="move_group_wait_for_servers" value="45.0"/>
    <param name="move_group_reinit_sleep" value="1.0"/>
    <!-- 仿真：myam_sys_moveit/trajectory_execution.launch.xml 已可关 execution_duration_monitoring；改后须重启 move_group + Gazebo 控制器 -->
    <param name="vision_cartesian_vel_scale" value="0.4"/>
    <param name="vision_cartesian_interp_steps" value="12"/>
    <param name="vision_cartesian_interp_steps_fin" value="8"/>
    <param name="vision_cartesian_step_m" value="0.03"/>
    <param name="vision_use_cartesian" value="true"/>
    <!-- 分段用 pose 目标（保持腕部姿态），避免仅位置 IK 大关节运动超时；失败后再 vision_pose_fallback 两步 -->
    <param name="vision_cartesian_use_pose" value="true"/>
    <param name="vision_pose_fallback" value="true"/>
    <param name="vision_goal_position_tolerance" value="0.065"/>
    <param name="vision_goal_orientation_tolerance" value="0.45"/>
    <param name="vision_relaxed_joint_tolerance" value="0.22"/>
    <!-- 默认 false：跳过多段笛卡尔，减少 TIMED_OUT；需调试分段时再设 true -->
    <param name="vision_segmented_cartesian_first" value="false"/>
    <param name="vision_pose_step_vel_scale" value="0.11"/>
    <!-- 小块/远距：略降面积阈值；腐蚀过强会吃掉小连通域 -->
    <param name="min_blob_area" value="18"/>
    <!-- Gazebo 蓝块常偏青/略灰，略放宽 H、S、V 下限 -->
    <rosparam param="hsv_blue_lower">[72, 18, 25]</rosparam>
    <rosparam param="hsv_blue_upper">[138, 255, 255]</rosparam>
    <!-- 与 MoveIt planning_frame 一致，避免用 map（易与相机 TF 断树） -->
    <param name="tf_refine_target_frame" value="roarm_base_link"/>
    <param name="blue_mask_erode_iters" value="0"/>
    <param name="blue_mask_dilate_iters" value="2"/>
    <!-- 检测阶段：深度定标 + TF 把像素偏差转成 LOCAL 水平修正量 -->
    <param name="detect_refine_xy_enable" value="true"/>
    <param name="detect_refine_xy_gain" value="0.22"/>
    <param name="detect_refine_xy_max_step" value="0.028"/>
    <param name="detect_refine_descend_enable" value="true"/>
    <param name="detect_refine_descend_step" value="0.05"/>
    <param name="detect_refine_descend_after_sec" value="2.2"/>
    <rosparam param="pregrasp_joints">[0.0, -0.95, 2.35, -0.4, 0.0]</rosparam>
    <rosparam param="grasp_joints">[0.0, -1.05, 2.55, -0.5, 0.0]</rosparam>
  </node>
</launch>
