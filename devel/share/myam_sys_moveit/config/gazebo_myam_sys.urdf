    <child link="hand_tcp"/>
  </joint>
  <!-- Effort-based transmissions for Gazebo + ros_control.
         This is preferred for the PX4 joint-simulation path because it avoids
         the extra gazebo_ros_control inner position loop required by PositionJointInterface. -->
  <transmission name="base_link_to_link1_tran">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="base_link_to_link1">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="base_link_to_link1_actr">
